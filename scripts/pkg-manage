#!/usr/bin/env bash

# Packages that are built locally and not available in Arch/AUR
# These are excluded from both save and install operations globally
GLOBAL_EXCLUDE=(
    "php74-*" # php74 will install all php74-* pkgs
)

PKG_FILE="$DOTFILES/pkgs.txt"
PKG_ALL_FILE="$DOTFILES/pkgs-all.txt"
PKG_CUSTOM_FILE="$DOTFILES/pkg-custom.txt"
MIGRATION_DIR="$DOTFILES/pkg_migrations"

EXCLUDE_PATTERNS=(
    # PHP7 has to manually installed
    "php74*"
    # Not always a amd machine
    "amd-ucode"
    # Will need paru to install, so no need to reinstall it self
    "paru*"
    # Well, my working machine should not have steam
    "steam"
    "*proton*"
    # If not dual boot windows with arch, no need
    "os-prober"
    # Working PC no need chinese keyboard
    "*rime*"
    "*fcitx5*"
    # No need all the browsers
    "chromium"
    "firefox"
    "chrome"
    # Manual install
    "yay*"
    # For wheel simulator
    "oversteer"
)

function create_migration() {
    local old_file="$1"
    local new_file="$2"
    local timestamp
    timestamp=$(date +"%Y%m%d_%H%M%S")
    local migration_file="$MIGRATION_DIR/${timestamp}_pkg_migration.sh"

    # Ensure migration directory exists
    mkdir -p "$MIGRATION_DIR"

    # Read old and new package lists
    local -a old_pkgs new_pkgs
    if [[ -f "$old_file" ]]; then
        mapfile -t old_pkgs <"$old_file"
    fi
    mapfile -t new_pkgs <"$new_file"

    # Find added and removed packages
    local -a added removed

    # Find added packages (in new but not in old)
    for pkg in "${new_pkgs[@]}"; do
        local found=false
        for old_pkg in "${old_pkgs[@]}"; do
            if [[ "$pkg" == "$old_pkg" ]]; then
                found=true
                break
            fi
        done
        if ! $found; then
            added+=("$pkg")
        fi
    done

    # Find removed packages (in old but not in new)
    for pkg in "${old_pkgs[@]}"; do
        local found=false
        for new_pkg in "${new_pkgs[@]}"; do
            if [[ "$pkg" == "$new_pkg" ]]; then
                found=true
                break
            fi
        done
        if ! $found; then
            removed+=("$pkg")
        fi
    done

    # Only create migration if there are changes
    if [[ ${#added[@]} -eq 0 && ${#removed[@]} -eq 0 ]]; then
        echo "No package changes detected. No migration created."
        return
    fi

    # Create migration file
    cat >"$migration_file" <<'EOF'
#!/usr/bin/env bash
set -e

echo "Running package migration: $(basename "$0")"
echo "========================================"

EOF

    # Add removal commands
    if [[ ${#removed[@]} -gt 0 ]]; then
        cat >>"$migration_file" <<EOF

echo "Removing ${#removed[@]} package(s)..."
EOF
        for pkg in "${removed[@]}"; do
            echo "err=\$(sudo pacman -Rns --noconfirm '$pkg' 2>&1) || echo \"\$err\"" >>"$migration_file"
        done
    fi

    # Add installation commands
    if [[ ${#added[@]} -gt 0 ]]; then
        cat >>"$migration_file" <<EOF

echo "Installing ${#added[@]} package(s)..."
EOF
        for pkg in "${added[@]}"; do
            echo "sudo pacman -S --needed --noconfirm '$pkg'" >>"$migration_file"
        done
    fi

    cat >>"$migration_file" <<'EOF'

echo "========================================"
echo "Migration completed successfully!"
EOF

    # Make migration executable
    chmod +x "$migration_file"

    echo ""
    echo "Migration created: $migration_file"
    echo "  - Added: ${#added[@]} package(s)"
    echo "  - Removed: ${#removed[@]} package(s)"
    echo ""
    echo "To apply this migration, run: $migration_file"
}

function save_packages() {
    echo "Saving explicitly installed packages from official repos only..."
    local all_pkgs
    # Only explicitly installed packages from official repos (excludes AUR and local PKGBUILDs)
    mapfile -t all_pkgs < <(pacman -Qneq)

    # Create temporary files for new package lists
    local tmp_all
    tmp_all=$(mktemp)
    local tmp_filtered
    tmp_filtered=$(mktemp)

    # Exclude globally excluded packages from the complete list too
    local all_filtered_pkgs=()
    for pkg in "${all_pkgs[@]}"; do
        local skip=false
        for excluded in "${GLOBAL_EXCLUDE[@]}"; do
            # Intentional glob pattern matching - do not quote
            # shellcheck disable=SC2053
            if [[ $pkg == $excluded ]]; then
                echo "Globally excluding package: $pkg"
                skip=true
                break
            fi
        done
        if ! $skip; then
            all_filtered_pkgs+=("$pkg")
        fi
    done

    # Save complete package list to temp (minus global excludes)
    printf "%s\n" "${all_filtered_pkgs[@]}" >"$tmp_all"

    # Save filtered package list to temp
    local filtered_pkgs=()
    for pkg in "${all_filtered_pkgs[@]}"; do
        local skip=false
        for pattern in "${EXCLUDE_PATTERNS[@]}"; do
            # Intentional glob pattern matching - do not quote
            # shellcheck disable=SC2053
            if [[ $pkg == $pattern ]]; then
                echo "Excluding package: $pkg"
                skip=true
                break
            fi
        done
        if ! $skip; then
            filtered_pkgs+=("$pkg")
        fi
    done
    printf "%s\n" "${filtered_pkgs[@]}" >"$tmp_filtered"

    # Create migrations before updating files
    echo ""
    echo "Checking for package changes..."
    create_migration "$PKG_FILE" "$tmp_filtered"

    # Move temp files to actual files
    mv "$tmp_all" "$PKG_ALL_FILE"
    mv "$tmp_filtered" "$PKG_FILE"

    echo ""
    echo "Saved $(wc -l <"$PKG_ALL_FILE") packages to $PKG_ALL_FILE (complete list)."
    echo "Saved $(wc -l <"$PKG_FILE") packages to $PKG_FILE (filtered list, excludes: ${EXCLUDE_PATTERNS[*]})."
}

function save_custom() {
    echo "Saving custom packages (AUR / local PKGBUILDs)..."
    local custom_pkgs
    # Explicitly installed packages not from official repos (AUR / local PKGBUILDs)
    mapfile -t custom_pkgs < <(pacman -Qemq)

    # Filter out globally excluded packages
    local filtered_custom=()
    for pkg in "${custom_pkgs[@]}"; do
        local skip=false
        for excluded in "${GLOBAL_EXCLUDE[@]}"; do
            # Intentional glob pattern matching - do not quote
            # shellcheck disable=SC2053
            if [[ $pkg == $excluded ]]; then
                echo "Globally excluding custom package: $pkg"
                skip=true
                break
            fi
        done
        if ! $skip; then
            filtered_custom+=("$pkg")
        fi
    done

    printf "%s\n" "${filtered_custom[@]}" >"$PKG_CUSTOM_FILE"
    echo "Saved $(wc -l <"$PKG_CUSTOM_FILE") custom packages to $PKG_CUSTOM_FILE."
}

function install_packages() {
    local use_all=false
    local target_file="$PKG_FILE"

    # Parse the all flag
    if [[ "$1" == "--all" ]]; then
        use_all=true
        target_file="$PKG_ALL_FILE"
    fi

    if [[ ! -f "$target_file" ]]; then
        echo "Error: $target_file not found. Please run with 'save' first."
        exit 1
    fi

    if $use_all; then
        echo "Installing ALL packages from $target_file using pacman..."
    else
        echo "Installing filtered packages from $target_file using pacman..."
    fi

    # Filter out globally excluded packages before installing
    local -a pkgs_to_install=()
    while IFS= read -r pkg; do
        [[ -z "$pkg" ]] && continue
        local skip=false
        for excluded in "${GLOBAL_EXCLUDE[@]}"; do
            # Intentional glob pattern matching - do not quote
            # shellcheck disable=SC2053
            if [[ $pkg == $excluded ]]; then
                echo "Skipping globally excluded package: $pkg"
                skip=true
                break
            fi
        done
        if ! $skip; then
            pkgs_to_install+=("$pkg")
        fi
    done <"$target_file"

    if [[ ${#pkgs_to_install[@]} -eq 0 ]]; then
        echo "No packages to install."
        return
    fi

    sudo pacman -S --needed --noconfirm "${pkgs_to_install[@]}"
    echo "Packages installed successfully."
}

function usage() {
    echo "Usage: $0 {save|save-custom|install [--all]}"
    echo "  save           - Save packages to both $PKG_FILE (filtered) and $PKG_ALL_FILE (complete)"
    echo "                   Also updates $PKG_CUSTOM_FILE"
    echo "                   Creates migration file in $MIGRATION_DIR if changes detected"
    echo "  save-custom    - Save custom packages (AUR / local PKGBUILDs) to $PKG_CUSTOM_FILE"
    echo "  install        - Install filtered packages from $PKG_FILE using pacman"
    echo "  install --all  - Install all packages from $PKG_ALL_FILE using pacman"
    echo ""
    echo "This script uses pacman and does not install AUR packages. Manage AUR packages manually."
    echo "Migration files are created automatically and can be run independently to apply changes."
}

# Main
case "$1" in
save)
    save_packages
    save_custom
    ;;
install)
    install_packages "$2"
    ;;
*)
    usage
    exit 1
    ;;
esac
