#!/usr/bin/env bash

# Git worktree helpers (inspired by DHH)
# https://gist.github.com/dhh/18575558fc5ee10f15b6cd3e108ed844

set -euo pipefail

if [[ -z "$1" ]]; then
  echo "Usage: git-worktree-add [branch name]"
  exit 1
fi

branch="$1"
base="$(basename "$PWD")"
path="$(dirname "$PWD")/${base}--${branch}"

git worktree add -b "$branch" "$path"

for env_file in "$PWD"/.env*; do
  [[ -f "$env_file" ]] && cp "$env_file" "$path/"
done

if [[ -n $TMUX ]]; then
  $(dirname "$0")/sessionizer "$path"
else
  cd "$path"
fi
