{
  "$schema": "https://opencode.ai/config.json",
  "theme": "default",
  "keybinds": {
    "input_newline": "return,ctrl+j,shift+return",
    "input_submit": "ctrl+return,alt+return",
    "session_interrupt": "ctrl+q"
  },
  "permission": {
    "*": "allow",
    "bash": "ask",
    "external_directory": "ask"
  }
}
