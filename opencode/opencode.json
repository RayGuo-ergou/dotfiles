{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "*": "ask",
    "grep": "allow",
    "glob": "allow",
    "edit": "allow",
    "todowrite": "allow",
    "task": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "*.key": "deny",
      "*.pem": "deny",
      "id_rsa*": "deny",
      "id_ed25519": "deny",
      ".aws/credentials": "deny",
      ".gcloud/**": "deny"
    },
    "bash": {
      "*": "ask",
      "git status": "allow",
      "git diff": "allow",
      "pnpm test": "allow",
      "pnpm lint": "allow",
      "pnpm lint:fix": "allow",
      "vendor/bin/pint*": "allow",
      "./vendor/bin/pint*": "allow",
      "php artisan test*": "allow",
      "ast-grep*": "allow",
      "rm -rf*": "deny",
      "rm -f*": "deny",
      "rm -r*": "deny",
      "sudo*": "deny",
      "chmod*": "deny",
      "npm*": "deny",
      "npx*": "deny",
      "prientenv*": "deny",
      "docker*": "deny"
    },
    "external_directory": "ask",
    "skill": "allow"
  }
}
